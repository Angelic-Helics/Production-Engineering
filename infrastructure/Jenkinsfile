pipeline {
    agent any

    tools {
        jdk 'jdk21'
        gradle 'gradle-8'
    }

    environment {
        DOCKER_IMAGE_NAME = 'alexdatasap/prod-eng-img'
        GITHUB_REPOSITORY = 'Angelic-Helics/Production-Engineering'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                sh 'gradle clean build'
            }
        }

        stage('Determine Image Version') {
            steps {
                sh '''
                    git fetch --tags --force
                    LATEST_TAG="$(git tag --sort=-v:refname | head -n 1)"

                    if [ -z "$LATEST_TAG" ]; then
                        LATEST_TAG="1.0.0"
                    fi

                    MAJOR="$(echo "$LATEST_TAG" | cut -d. -f1)"
                    MINOR="$(echo "$LATEST_TAG" | cut -d. -f2)"
                    PATCH="$(echo "$LATEST_TAG" | cut -d. -f3)"

                    case "$MAJOR" in ''|*[!0-9]*) MAJOR=1 ;; esac
                    case "$MINOR" in ''|*[!0-9]*) MINOR=0 ;; esac
                    case "$PATCH" in ''|*[!0-9]*) PATCH=0 ;; esac

                    NEXT_MINOR=$((MINOR + 1))
                    IMAGE_VERSION="$MAJOR.$NEXT_MINOR.$PATCH"
                    IMAGE_TAG="$DOCKER_IMAGE_NAME:$IMAGE_VERSION"

                    echo "$IMAGE_VERSION" > .image-version
                    echo "$IMAGE_TAG" > .docker-image-tag
                    echo "Docker image version: $IMAGE_VERSION"
                    echo "Docker image tag: $IMAGE_TAG"
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t "$(cat .docker-image-tag)" .'
            }
        }

        stage('Login and Push Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker_password',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )]) {
                    sh '''
                        echo "$DOCKER_PASSWORD" | docker login docker.io -u "$DOCKER_USERNAME" --password-stdin
                        docker push "$(cat .docker-image-tag)"
                    '''
                }
            }
        }

        stage('Tag Git Release') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'github',
                    usernameVariable: 'GITHUB_USERNAME',
                    passwordVariable: 'GITHUB_TOKEN'
                )]) {
                    sh '''
                        IMAGE_VERSION="$(cat .image-version)"

                        git config user.email "jenkins@local"
                        git config user.name "Jenkins"

                        if git rev-parse "$IMAGE_VERSION" >/dev/null 2>&1; then
                            echo "Git tag $IMAGE_VERSION already exists."
                        else
                            git tag "$IMAGE_VERSION"
                        fi

                        git push "https://${GITHUB_USERNAME}:${GITHUB_TOKEN}@github.com/${GITHUB_REPOSITORY}.git" "$IMAGE_VERSION"
                    '''
                }
            }
        }

        stage('Deploy Application') {
            steps {
                sh '''
                    IMAGE_TAG="$(cat .docker-image-tag)"

                    docker network create prodeng_default || true
                    docker rm -f prodeng-prod-eng-1 prodeng-mongo-1 || true

                    docker run -d \
                        --name prodeng-mongo-1 \
                        --network prodeng_default \
                        -p 27017:27017 \
                        -e MONGO_INITDB_ROOT_USERNAME=root \
                        -e MONGO_INITDB_ROOT_PASSWORD=example \
                        mongo:6.0.20

                    docker run -d \
                        --name prodeng-prod-eng-1 \
                        --network prodeng_default \
                        -p 8080:8080 \
                        -p 5005:5005 \
                        -e ENVIRONMENT_NAME=local \
                        -e MONGODB_CONECTION_URL=mongodb://root:example@prodeng-mongo-1:27017/ \
                        "$IMAGE_TAG"
                '''
            }
        }

        stage('Integration Tests') {
            steps {
                sh 'TESTCONTAINERS_RYUK_DISABLED=true MONGODB_TEST_HOST=host.docker.internal gradle testIT'
            }
        }
    }
}
