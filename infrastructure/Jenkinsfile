pipeline {
    agent any

    tools {
        jdk 'jdk21'
        gradle 'gradle-8'
    }

    environment {
        DOCKER_IMAGE_NAME = 'alexdatasap/prod-eng-img'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build & Test') {
            steps {
                sh 'gradle clean build'
            }
        }

        stage('Determine Image Version') {
            steps {
                sh '''
                    git fetch --tags --force
                    LATEST_TAG="$(git tag --sort=-v:refname | head -n 1)"

                    if [ -z "$LATEST_TAG" ]; then
                        LATEST_TAG="1.0.0"
                    fi

                    MAJOR="$(echo "$LATEST_TAG" | cut -d. -f1)"
                    MINOR="$(echo "$LATEST_TAG" | cut -d. -f2)"
                    PATCH="$(echo "$LATEST_TAG" | cut -d. -f3)"

                    case "$MAJOR" in ''|*[!0-9]*) MAJOR=1 ;; esac
                    case "$MINOR" in ''|*[!0-9]*) MINOR=0 ;; esac
                    case "$PATCH" in ''|*[!0-9]*) PATCH=0 ;; esac

                    NEXT_MINOR=$((MINOR + 1))
                    IMAGE_TAG="$DOCKER_IMAGE_NAME:$MAJOR.$NEXT_MINOR.$PATCH"

                    echo "$IMAGE_TAG" > .docker-image-tag
                    echo "Docker image tag: $IMAGE_TAG"
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t "$(cat .docker-image-tag)" .'
            }
        }

        stage('Login and Push Image') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker_password',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )]) {
                    sh '''
                        echo "$DOCKER_PASSWORD" | docker login docker.io -u "$DOCKER_USERNAME" --password-stdin
                        docker push "$(cat .docker-image-tag)"
                    '''
                }
            }
        }
    }
}
