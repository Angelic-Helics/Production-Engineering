# You can use this file to easily send requests to your API.
# Prerequisite: humao.rest-client Vscode plugin

# TIP: Run requests in order - later requests reference IDs from earlier responses


# ==========================================
# Customer Controller Endpoints
# ==========================================

### Get all customers
GET http://localhost:8080/api/customers

### Create a new customer
# @name createCustomer
POST http://localhost:8080/api/customers
Content-Type: application/json

{
    "name": "Jean Valjean",
    "email": "jean.valjean@kitchenflow.ro",
    "phoneNumber": "+40123456789"
}

### Get customer by ID
GET http://localhost:8080/api/customers/{{createCustomer.response.body.id}}

### Get customer by email
GET http://localhost:8080/api/customers/by-email?email={{createCustomer.response.body.email}}

### Update customer details
PUT http://localhost:8080/api/customers/{{createCustomer.response.body.id}}
Content-Type: application/json

{
    "name": "Monsieur Madeleine",
    "phoneNumber": "+40987654321"
}


# ==========================================
# Order Controller Endpoints
# ==========================================

### Create a new order
# @name createOrder
POST http://localhost:8080/api/orders
Content-Type: application/json

{
    "itemName": "Margherita Pizza",
    "quantity": 2,
    "customerEmail": "{{createCustomer.response.body.email}}",
    "specialInstructions": "Extra basil"
}

### Get orders by customer email
GET http://localhost:8080/api/orders?customerEmail={{createCustomer.response.body.email}}

### Get order by ID
GET http://localhost:8080/api/orders/{{createOrder.response.body.id}}

### Update order status to PREPARING
PATCH http://localhost:8080/api/orders/{{createOrder.response.body.id}}/status
Content-Type: application/json

{
    "status": "PREPARING"
}

### Update order status to READY
PATCH http://localhost:8080/api/orders/{{createOrder.response.body.id}}/status
Content-Type: application/json

{
    "status": "READY"
}


# ==========================================
# Cleanup
# ==========================================

### Delete order
DELETE http://localhost:8080/api/orders/{{createOrder.response.body.id}}

### Delete customer
DELETE http://localhost:8080/api/customers/{{createCustomer.response.body.id}}
